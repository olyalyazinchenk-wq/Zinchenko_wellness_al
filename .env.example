# LLM: text reasoning/drafts/replies. For DeepSeek use:
# LLM_PROVIDER=openai_compatible
# LLM_API_KEY=sk-...
# LLM_MODEL=deepseek-v4-flash
# LLM_API_MODE=chat_completions
# LLM_BASE_URL=https://api.deepseek.com
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=
LLM_API_MODE=responses
LLM_BASE_URL=
LLM_PROJECT_ID=
LLM_DISABLE_SERVER_LOGGING=true
LLM_USE_IAM_TOKEN=false

# STT: voice/audio transcription. Keep Yandex SpeechKit here even when LLM is DeepSeek.
STT_PROVIDER=disabled
STT_API_KEY=
STT_PROJECT_ID=
STT_USE_IAM_TOKEN=false
