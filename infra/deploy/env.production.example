# Required
BOT_TOKEN=
ADMIN_CHAT_IDS=

# Usually empty on Linux VPS unless Telegram access requires a proxy.
BOT_PROXY_URL=

# Payments. Keep empty until a live provider token is ready.
PAYMENT_TOKEN=

# LLM modes:
#   disabled
#   openai
#   openai_compatible
#   yandex_ai_studio
#   yandex_foundation
LLM_PROVIDER=disabled
LLM_API_KEY=
LLM_MODEL=
LLM_API_MODE=responses
LLM_BASE_URL=
LLM_PROJECT_ID=
LLM_DISABLE_SERVER_LOGGING=true
LLM_USE_IAM_TOKEN=false

# Keep disabled until the Telegram Mini App surface is hardened and intentionally exposed.
ENABLE_TMA=false
